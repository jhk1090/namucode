{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "injectionSelector": "L:source.namu -meta.embedded.inline.javascript",
    "name": "나무코드 매개변수 처리 부분",
    "scopeName": "source.namu.arguments",
    "patterns": [
        {
            "include": "#arguments"
        }
    ],
    "repository": {
        "arguments": {
            "name": "support.variable.namu",
            "match": "@([\\p{L}\\p{N}_]*)(=[^\\n\\r@]+)?@"
        }
    }
}
