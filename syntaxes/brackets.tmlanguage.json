{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "injectionSelector": "L:source.namu -meta.embedded -markup.raw.block",
  "name": "나무코드 중괄호 처리 부분",
  "scopeName": "source.namu.brackets",
  "patterns": [
    {
      "include": "#brackets-scaleText"
    },
    {
      "include": "#brackets-colorText"
    },
    {
      "include": "#brackets-folding"
    },
    {
      "include": "#brackets-folding-forCompletion"
    },
    {
      "include": "#brackets-wikiSyntax"
    },
    {
      "include": "#brackets-htmlSyntax"
    },
    {
      "include": "#brackets-ifSyntax"
    },
    {
      "include": "#brackets-ifSyntax-forCompletion"
    },
    {
      "include": "#brackets-styleSyntax"
    },
    {
      "include": "#brackets-styleSyntax-forCompletion"
    },
    {
      "include": "#brackets-syntaxSyntax"
    },
    {
      "include": "#brackets-raw"
    }
  ],
  "repository": {
    "brackets-scaleText": {
      "begin": "\\{\\{\\{((?:\\+|\\-)[1-5]) ",
      "beginCaptures": {
        "1": { "name": "support.constant.color.namu" }
      },
      "end": "\\}\\}\\}",
      "patterns": [{ "include": "source.namu" }]
    },
    "brackets-colorText": {
      "begin": "(?i)\\{\\{\\{(#(?:AliceBlue|AntiqueWhite|Aqua|Aquamarine|Azure|Beige|Bisque|Black|BlanchedAlmond|Blue|BlueViolet|Brown|BurlyWood|CadetBlue|Chartreuse|Chocolate|Coral|CornflowerBlue|Cornsilk|Crimson|Cyan|DarkBlue|DarkCyan|DarkGoldenRod|DarkGray|DarkGrey|DarkGreen|DarkKhaki|DarkMagenta|DarkOliveGreen|DarkOrange|DarkOrchid|DarkRed|DarkSalmon|DarkSeaGreen|DarkSlateBlue|DarkSlateGray|DarkSlateGrey|DarkTurquoise|DarkViolet|DeepPink|DeepSkyBlue|DimGray|DimGrey|DodgerBlue|FireBrick|FloralWhite|ForestGreen|Fuchsia|Gainsboro|GhostWhite|Gold|GoldenRod|Gray|Grey|Green|GreenYellow|HoneyDew|HotPink|IndianRed|Indigo|Ivory|Khaki|Lavender|LavenderBlush|LawnGreen|LemonChiffon|LightBlue|LightCoral|LightCyan|LightGoldenRodYellow|LightGray|LightGrey|LightGreen|LightPink|LightSalmon|LightSeaGreen|LightSkyBlue|LightSlateGray|LightSlateGrey|LightSteelBlue|LightYellow|Lime|LimeGreen|Linen|Magenta|Maroon|MediumAquaMarine|MediumBlue|MediumOrchid|MediumPurple|MediumSeaGreen|MediumSlateBlue|MediumSpringGreen|MediumTurquoise|MediumVioletRed|MidnightBlue|MintCream|MistyRose|Moccasin|NavajoWhite|Navy|OldLace|Olive|OliveDrab|Orange|OrangeRed|Orchid|PaleGoldenRod|PaleGreen|PaleTurquoise|PaleVioletRed|PapayaWhip|PeachPuff|Peru|Pink|Plum|PowderBlue|Purple|RebeccaPurple|Red|RosyBrown|RoyalBlue|SaddleBrown|Salmon|SandyBrown|SeaGreen|SeaShell|Sienna|Silver|SkyBlue|SlateBlue|SlateGray|SlateGrey|Snow|SpringGreen|SteelBlue|Tan|Teal|Thistle|Tomato|Turquoise|Violet|Wheat|White|WhiteSmoke|Yellow|YellowGreen|[A-Fa-f0-9]{3,6})(?:,#(?:AliceBlue|AntiqueWhite|Aqua|Aquamarine|Azure|Beige|Bisque|Black|BlanchedAlmond|Blue|BlueViolet|Brown|BurlyWood|CadetBlue|Chartreuse|Chocolate|Coral|CornflowerBlue|Cornsilk|Crimson|Cyan|DarkBlue|DarkCyan|DarkGoldenRod|DarkGray|DarkGrey|DarkGreen|DarkKhaki|DarkMagenta|DarkOliveGreen|DarkOrange|DarkOrchid|DarkRed|DarkSalmon|DarkSeaGreen|DarkSlateBlue|DarkSlateGray|DarkSlateGrey|DarkTurquoise|DarkViolet|DeepPink|DeepSkyBlue|DimGray|DimGrey|DodgerBlue|FireBrick|FloralWhite|ForestGreen|Fuchsia|Gainsboro|GhostWhite|Gold|GoldenRod|Gray|Grey|Green|GreenYellow|HoneyDew|HotPink|IndianRed|Indigo|Ivory|Khaki|Lavender|LavenderBlush|LawnGreen|LemonChiffon|LightBlue|LightCoral|LightCyan|LightGoldenRodYellow|LightGray|LightGrey|LightGreen|LightPink|LightSalmon|LightSeaGreen|LightSkyBlue|LightSlateGray|LightSlateGrey|LightSteelBlue|LightYellow|Lime|LimeGreen|Linen|Magenta|Maroon|MediumAquaMarine|MediumBlue|MediumOrchid|MediumPurple|MediumSeaGreen|MediumSlateBlue|MediumSpringGreen|MediumTurquoise|MediumVioletRed|MidnightBlue|MintCream|MistyRose|Moccasin|NavajoWhite|Navy|OldLace|Olive|OliveDrab|Orange|OrangeRed|Orchid|PaleGoldenRod|PaleGreen|PaleTurquoise|PaleVioletRed|PapayaWhip|PeachPuff|Peru|Pink|Plum|PowderBlue|Purple|RebeccaPurple|Red|RosyBrown|RoyalBlue|SaddleBrown|Salmon|SandyBrown|SeaGreen|SeaShell|Sienna|Silver|SkyBlue|SlateBlue|SlateGray|SlateGrey|Snow|SpringGreen|SteelBlue|Tan|Teal|Thistle|Tomato|Turquoise|Violet|Wheat|White|WhiteSmoke|Yellow|YellowGreen|[A-Fa-f0-9]{3,6}))?)( |$)",
      "beginCaptures": {
        "1": { "name": "support.constant.color.namu" }
      },
      "end": "\\}\\}\\}",
      "patterns": [{ "include": "source.namu" }]
    },
    "brackets-folding": {
      "begin": "\\{\\{\\{(#!folding)([^\\}]*)$",
      "beginCaptures": {
        "1": { "name": "keyword.control.bracket.namu" },
        "2": { "name": "string.quoted.other.namu" }
      },
      "end": "\\}\\}\\}",
      "patterns": [{ "include": "source.namu" }]
    },
    "brackets-folding-forCompletion": {
      "comment": "자연스러운 구문 완성을 위한 지원",
      "begin": "\\{\\{\\{(#!folding)",
      "beginCaptures": {
        "1": { "name": "keyword.control.bracket.namu" }
      },
      "end": "\\}\\}\\}"
    },
    "brackets-wikiSyntax": {
      "begin": "\\{\\{\\{(#!wiki)(.*)$",
      "beginCaptures": {
        "1": { "name": "keyword.control.bracket.namu" },
        "2": {
          "patterns": [
            {
              "match": "(style|dark-style)=\\\"([^\"]*)(\\\")?",
              "captures": {
                "1": { "name": "variable.parameter.bracket.namu" },
                "2": {
                  "name": "meta.embedded.line.css",
                  "patterns": [
                    {
                      "include": "source.css#rule-list-innards"
                    }
                  ]
                }
              }
            },
            {
              "match": "(class|lang)=\\\"([^\"]*)(\\\")?",
              "captures": {
                "1": { "name": "variable.parameter.bracket.namu" },
                "2": {
                  "name": "string.quoted.double.namu"
                }
              }
            }
          ]
        }
      },
      "end": "\\}\\}\\}",
      "patterns": [{ "include": "source.namu" }]
    },
    "brackets-htmlSyntax": {
      "begin": "\\{\\{\\{(#!html)",
      "beginCaptures": {
        "1": { "name": "keyword.control.bracket.namu" }
      },
      "end": "\\}\\}\\}",
      "contentName": "meta.embedded.block.html",
      "patterns": [{ "include": "text.html.derivative" }]
    },
    "brackets-ifSyntax": {
      "begin": "\\{\\{\\{(#!if) (.*)$",
      "beginCaptures": {
        "1": { "name": "keyword.control.bracket.namu" },
        "2": { "name": "meta.embedded.inline.javascript", "patterns": [{ "include": "source.js" }] }
      },
      "end": "\\}\\}\\}",
      "patterns": [{ "include": "source.namu" }]
    },
    "brackets-ifSyntax-forCompletion": {
      "comment": "자연스러운 구문 완성을 위한 지원",
      "begin": "\\{\\{\\{(#!if)",
      "beginCaptures": {
        "1": { "name": "keyword.control.bracket.namu" }
      },
      "end": "\\}\\}\\}"
    },
    "brackets-styleSyntax": {
      "begin": "\\{\\{\\{(#!style)$",
      "beginCaptures": {
        "1": { "name": "keyword.control.bracket.namu" }
      },
      "end": "\\}\\}\\}",
      "contentName": "meta.embedded.block.css",
      "patterns": [{ "include": "source.css" }]
    },
    "brackets-styleSyntax-forCompletion": {
